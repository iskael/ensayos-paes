# Copiar a .env y ajustar
PORT=8080
# Valores por defecto: coinciden con docker-compose.yml (make db-up)
DATABASE_URL=postgres://ensayos:ensayos@localhost:5432/ensayos_paes?sslmode=disable
JWT_SECRET=cambiar-por-un-secreto-largo-y-aleatorio
JWT_TTL_HORAS=24
UPLOADS_DIR=./uploads
UPLOADS_URL=http://localhost:8080/uploads
CORS_ALLOWED_ORIGIN=*

# --- Solo para docker-compose.yml (stack completo: db + migrate + api + web) ---
POSTGRES_USER=ensayos
POSTGRES_PASSWORD=ensayos
POSTGRES_DB=ensayos_paes
